# Cloudflare API (required for both options)
# Create token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Account - Cloudflare Pages: Edit, Zone - Zone: Edit, Zone - DNS: Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Pages project name
CLOUDFLARE_PAGES_PROJECT=what-can-janet-do

# Namecheap API (required for both options)
# Enable at: Profile → Tools → API Access
# Whitelist your IP in API access
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
# Your whitelisted IP, or leave empty to auto-detect via curl ifconfig.me
NAMECHEAP_CLIENT_IP=

# Custom domain
DOMAIN=heyjanet.org
PAGES_CNAME_TARGET=what-can-janet-do.pages.dev
